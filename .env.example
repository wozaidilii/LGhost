# Next Auth
AUTH_SECRET=""
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# 可选；自定义域名时设为完整 URL，例如 https://lghost.loamly.net
# 不填也可（已启用 trustHost），但若填写必须是带 https:// 的完整 URL
AUTH_URL=""

# OpenAI Realtime API
OPENAI_API_KEY=""

# Prisma — 本地 Docker Postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/L-Ghost"
# Neon 生产库见 .env.neon（gitignore，从 Neon/Vercel Dashboard 复制）
# DATABASE_URL_UNPOOLED 仅 prisma migrate 时需要，本地可与 DATABASE_URL 相同
